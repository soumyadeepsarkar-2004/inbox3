# Aptos Network Configuration
# Supported values: testnet, devnet, mainnet
VITE_NETWORK=testnet

# Your deployed Smart Contract Address (pre-filled with live testnet address)
VITE_CONTRACT_ADDRESS=0x2fb49669a943f53c7a0ab469e3fc475b273697f0151554e8321646895ca55d0e

# Required for persistent message storage on IPFS via Pinata
# Get keys from: https://pinata.cloud/keys
VITE_PINATA_API_KEY=your_pinata_api_key
VITE_PINATA_SECRET_KEY=your_pinata_secret_key
VITE_PINATA_GATEWAY=gateway.pinata.cloud

# Optional: WebSocket Signaling Server for P2P voice/video calls
# If not set, calling features will be disabled
# Local: ws://localhost:8080
# Production example: wss://your-signaling-server.onrender.com
# VITE_SIGNALING_SERVER_URL=wss://your-signaling-server.onrender.com
