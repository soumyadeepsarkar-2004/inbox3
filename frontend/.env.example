# ============================================================
# Inbox3 Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to git.
# ============================================================

# --- Aptos Smart Contract (REQUIRED) ---
# Pre-filled with the live testnet deployment. Only change this if you redeploy.
VITE_CONTRACT_ADDRESS=0x2fb49669a943f53c7a0ab469e3fc475b273697f0151554e8321646895ca55d0e

# --- Aptos Network (REQUIRED) ---
# Options: mainnet | testnet | devnet
VITE_NETWORK=testnet

# --- Pinata IPFS (REQUIRED for persistent messages) ---
# Sign up at https://pinata.cloud and create API keys
VITE_PINATA_API_KEY=
VITE_PINATA_SECRET_KEY=
# Optional: use a dedicated gateway (e.g. https://myapp.mypinata.cloud)
VITE_PINATA_GATEWAY=gateway.pinata.cloud

# --- WebRTC Signaling Server (REQUIRED for voice/video calls) ---
# Deploy the signaling server (see /signaling-server/README.md)
# Then paste its WebSocket URL here.
# Example: wss://my-signaling-server.onrender.com
VITE_SIGNALING_SERVER_URL=
